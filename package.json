{
  "name": "adanaemlakofisi",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/hostinger-build.mjs",
    "build:next": "next build",
    "start": "node scripts/hostinger-start.mjs",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:target:sqlite": "node scripts/set-db-target.mjs sqlite",
    "db:target:postgres": "node scripts/set-db-target.mjs postgres",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup:postgres": "node scripts/set-db-target.mjs postgres && docker compose up -d && prisma migrate deploy && tsx prisma/seed.ts",
    "build:postgres": "node scripts/set-db-target.mjs postgres && prisma generate && prisma migrate deploy && next build",
    "admin:hash-password": "tsx scripts/hash-password.ts",
    "postinstall": "node scripts/set-db-target.mjs sqlite && prisma generate"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^6.9.0",
    "next": "^15.3.3",
