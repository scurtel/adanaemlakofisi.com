# Site
NEXT_PUBLIC_SITE_URL=https://adanaemlakofisi.com

# Veritabanı
# Local: file:./dev.db
# Hostinger SQLite örneği: file:./prisma/production.db
# PostgreSQL örneği: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# Gemini API (kodda GEMINI_API_KEY kullanılır)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Admin paneli
ADMIN_EMAIL=
# Düz şifre değil — npm run admin:hash-password -- Sifreniz ile üretin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Opsiyonel
GOOGLE_SITE_VERIFICATION=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NOTIFICATION_EMAIL_TO=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
